---
import { Image } from 'astro:assets';
import logo from '../assets/images/logo/ggg-logo.png';

const navLinks = [
  { label: 'About', href: '/about' },
  { label: 'Residential', href: '/residential' },
  { label: 'Commercial', href: '/commercial' },
  { label: 'Service Areas', href: '/areas' },
];
---

<header id="site-header" style="position:fixed;top:0;left:0;right:0;z-index:50;background:rgba(255,255,255,0.97);border-bottom:1px solid rgba(74,140,74,0.1);transition:box-shadow 0.3s;">
  <div class="container" style="display:flex;align-items:center;justify-content:space-between;height:72px;padding-right:1.25rem;">
    <!-- Logo -->
    <a href="/" style="display:flex;align-items:center;flex-shrink:0;" aria-label="Gal Gone Green — Home">
      <Image
        src={logo}
        alt="Gal Gone Green logo"
        class="h-10 md:h-12 w-auto"
        widths={[200, 320]}
        sizes="(max-width: 768px) 200px, 320px"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="px-4 py-2 text-sm font-medium text-charcoal-light hover:text-green-700 rounded-lg transition-colors relative group"
        >
          {link.label}
          <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-green-600 transition-all duration-300 group-hover:w-3/4 rounded-full"></span>
        </a>
      ))}
      <a href="/contact" class="btn-primary ml-4 !py-2.5 !px-5 !text-sm">
        Book a Cleaning
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      type="button"
      style="flex-direction:column;justify-content:center;align-items:center;width:44px;height:44px;gap:5px;border-radius:8px;flex-shrink:0;background:none;border:none;cursor:pointer;padding:0;margin-right:8px;"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <!-- Hamburger icon -->
      <svg id="icon-hamburger" style="width:24px;height:24px;transition:opacity 0.2s;" fill="none" stroke="#2c2c2c" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
      <!-- X icon (hidden by default) -->
      <svg id="icon-close" style="width:24px;height:24px;display:none;transition:opacity 0.2s;" fill="none" stroke="#2c2c2c" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
  </div>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  style="position:fixed;top:72px;left:0;right:0;bottom:0;background:#ffffff;z-index:40;overflow-y:auto;opacity:0;visibility:hidden;transform:translateY(-10px);transition:opacity 0.25s ease,transform 0.25s ease,visibility 0.25s;"
>
  <nav style="display:flex;flex-direction:column;padding:2rem;gap:0.5rem;">
    {navLinks.map(link => (
      <a
        href={link.href}
        style="font-size:1.125rem;font-weight:500;color:#2c2c2c;padding:0.75rem 1rem;border-radius:12px;border-bottom:1px solid #f4f9f4;text-decoration:none;"
      >
        {link.label}
      </a>
    ))}
    <a href="/contact" class="btn-primary" style="margin-top:1.5rem;justify-content:center;text-align:center;">
      Book a Cleaning
    </a>
    <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid #e6f0e6;">
      <a href="tel:+15712097745" style="display:flex;align-items:center;gap:0.75rem;color:#4a4a4a;padding:0.5rem 0;text-decoration:none;font-size:0.875rem;">
        <svg style="width:20px;height:20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        (571) 209-7745
      </a>
      <a href="mailto:hello@galgonegreen.com" style="display:flex;align-items:center;gap:0.75rem;color:#4a4a4a;padding:0.5rem 0;text-decoration:none;font-size:0.875rem;">
        <svg style="width:20px;height:20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        hello@galgonegreen.com
      </a>
    </div>
  </nav>
</div>

<!-- Spacer to prevent content from hiding behind fixed header -->
<div style="height:72px;"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-hamburger');
  const iconClose = document.getElementById('icon-close');
  let isOpen = false;

  btn?.addEventListener('click', () => {
    isOpen = !isOpen;

    if (menu) {
      if (isOpen) {
        menu.style.opacity = '1';
        menu.style.visibility = 'visible';
        menu.style.transform = 'translateY(0)';
      } else {
        menu.style.opacity = '0';
        menu.style.visibility = 'hidden';
        menu.style.transform = 'translateY(-10px)';
      }
    }

    btn?.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';

    if (iconOpen && iconClose) {
      iconOpen.style.display = isOpen ? 'none' : 'block';
      iconClose.style.display = isOpen ? 'block' : 'none';
    }
  });

  // Close mobile menu on link click — fade out first, then navigate
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', (e) => {
      if (!isOpen) return;
      e.preventDefault();
      const href = link.getAttribute('href');

      // Close menu with animation
      btn?.click();

      // Navigate after the fade-out completes
      setTimeout(() => {
        if (href) window.location.href = href;
      }, 250);
    });
  });

  // Header shadow on scroll
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header!.style.boxShadow = '0 4px 6px -1px rgba(0,0,0,0.1)';
    } else {
      header!.style.boxShadow = 'none';
    }
  }, { passive: true });
</script>

<style>
  #mobile-menu-btn {
    display: flex;
  }
  @media (min-width: 1024px) {
    #mobile-menu-btn {
      display: none !important;
    }
  }
</style>
