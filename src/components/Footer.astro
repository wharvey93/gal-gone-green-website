---
import { Image } from 'astro:assets';
import logo from '../assets/images/logo/ggg-logo.png';

const serviceLinks = [
  { label: 'Residential Cleaning', href: '/residential' },
  { label: 'Commercial Cleaning', href: '/commercial' },
  { label: 'Deep Cleaning', href: '/residential#deep-cleaning' },
  { label: 'Recurring Cleaning', href: '/residential#recurring' },
  { label: 'Airbnb / Short-Term Rental', href: '/commercial#airbnb' },
];

const areaLinks = [
  { label: 'Harrisonburg', href: '/areas/harrisonburg' },
  { label: 'Broadway', href: '/areas/broadway' },
  { label: 'Bridgewater', href: '/areas/bridgewater' },
  { label: 'Dayton', href: '/areas/dayton' },
  { label: 'Staunton', href: '/areas/staunton' },
  { label: 'Elkton', href: '/areas/elkton' },
];
---

<footer class="bg-green-900 text-green-100 relative overflow-hidden">
  <!-- Decorative leaf pattern -->
  <div class="absolute top-0 right-0 w-96 h-96 opacity-5">
    <svg viewBox="0 0 400 400" fill="currentColor" class="text-green-300">
      <path d="M200 0C200 0 320 80 360 200C400 320 320 400 200 400C80 400 0 320 0 200C0 80 80 0 200 0ZM200 50C120 50 50 120 50 200C50 280 120 360 200 360C280 360 340 280 340 200C340 120 280 50 200 50Z" />
    </svg>
  </div>

  <div class="container section-padding">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4">
          <Image
            src={logo}
            alt="Gal Gone Green"
            class="h-10 w-auto brightness-0 invert opacity-90"
            widths={[400, 640]}
            sizes="320px"
            quality={90}
          />
        </a>
        <p class="text-green-200/80 text-sm leading-relaxed mb-6">
          Eco-friendly cleaning services for homes and businesses across the Shenandoah Valley. Locally owned since 2011.
        </p>
        <div class="flex gap-3">
          <a href="https://www.facebook.com/GalGoneGreenCleaning" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Facebook" class="w-10 h-10 rounded-full bg-green-800 hover:bg-green-700 flex items-center justify-center transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services Column -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4 font-[var(--font-body)]">Services</h3>
        <ul class="space-y-2.5">
          {serviceLinks.map(link => (
            <li>
              <a href={link.href} class="text-green-200/80 hover:text-white text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Service Areas Column -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4 font-[var(--font-body)]">Service Areas</h3>
        <ul class="space-y-2.5">
          {areaLinks.map(link => (
            <li>
              <a href={link.href} class="text-green-200/80 hover:text-white text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/areas" class="text-accent-400 hover:text-accent-300 text-sm font-medium transition-colors">
              View All Areas &rarr;
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4 font-[var(--font-body)]">Contact</h3>
        <ul class="space-y-3">
          <li>
            <a href="tel:+15712097745" class="flex items-start gap-3 text-green-200/80 hover:text-white text-sm transition-colors group">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-green-400 group-hover:text-accent-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              (571) 209-7745
            </a>
          </li>
          <li>
            <a href="mailto:hello@galgonegreen.com" class="flex items-start gap-3 text-green-200/80 hover:text-white text-sm transition-colors group">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-green-400 group-hover:text-accent-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              hello@galgonegreen.com
            </a>
          </li>
          <li>
            <a href="https://maps.google.com/?q=409+S+Main+Street+Broadway+VA+22815" target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 text-green-200/80 hover:text-white text-sm transition-colors group">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-green-400 group-hover:text-accent-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              409 S Main Street<br />Broadway, VA 22815
            </a>
          </li>
          <li class="pt-2">
            <a href="https://clienthub.getjobber.com/client_hubs/4377bb96-9218-44a1-a08d-28c4766d6af1/login/new?source=share_login" target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 text-accent-400 hover:text-accent-300 text-sm font-medium transition-colors group">
              <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" /></svg>
              Client Login
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-green-800">
    <div class="container py-5 flex flex-col sm:flex-row justify-between items-center gap-3 text-sm text-green-300/60">
      <p>&copy; {new Date().getFullYear()} GGG Cleaning LLC. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="/privacy" class="hover:text-green-200 transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-green-200 transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
