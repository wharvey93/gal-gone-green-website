---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "mainEntity": {
    "@type": "LocalBusiness",
    "name": "Gal Gone Green",
    "telephone": "+15712097745",
    "email": "hello@galgonegreen.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "409 S Main Street",
      "addressLocality": "Broadway",
      "addressRegion": "VA",
      "postalCode": "22815"
    }
  }
};

const serviceOptions = [
  'One-Time Deep Cleaning',
  'Recurring — Every 2 Weeks',
  'Recurring — Every Month',
  'Commercial / Office Cleaning',
  'Airbnb / Short-Term Rental',
  'Move-In / Move-Out',
  'Other',
];
---

<BaseLayout
  title="Contact Gal Gone Green | Book a Cleaning in Harrisonburg, VA"
  description="Ready to book a cleaning? Contact Gal Gone Green for a free quote. Serving Harrisonburg, Broadway, and the entire Shenandoah Valley. Call (571) 209-7745 or fill out our form."
  canonicalPath="/contact"
  schema={schema}
>
  <!-- Hero -->
  <section class="py-16 md:py-20 bg-green-800 relative grain">
    <div class="container relative z-10">
      <div class="max-w-2xl">
        <p class="text-green-300 font-medium text-sm uppercase tracking-widest mb-4 reveal">Get In Touch</p>
        <h1 class="text-white mb-4 reveal">Get in Touch</h1>
        <p class="text-green-100/80 text-lg leading-relaxed reveal">
          Tell us a little about what you're looking for and we'll reach out to learn more. No commitment, no pressure.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-cream">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Form -->
        <div class="lg:col-span-3 reveal">
          <div class="bg-white rounded-2xl p-8 md:p-10 shadow-sm">
            <h2 class="text-2xl mb-6">Request a Free Quote</h2>
            <form
              id="contact-form"
              action="https://formspree.io/f/placeholder"
              method="POST"
              class="space-y-5"
              data-emails="will@harvey-capital.com,hello@galgonegreen.com"
            >
              <!-- Honeypot -->
              <div class="hidden" aria-hidden="true">
                <label for="website">Website</label>
                <input type="text" name="website" id="website" tabindex="-1" autocomplete="off" />
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-medium text-charcoal mb-1.5">Name <span class="text-red-500">*</span></label>
                  <input type="text" id="name" name="name" required autocomplete="name"
                    class="w-full px-4 py-3 rounded-xl border border-warm-300 bg-warm-50 text-charcoal placeholder-charcoal-muted focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                    placeholder="Your name" />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-charcoal mb-1.5">Phone <span class="text-red-500">*</span></label>
                  <input type="tel" id="phone" name="phone" required autocomplete="tel"
                    class="w-full px-4 py-3 rounded-xl border border-warm-300 bg-warm-50 text-charcoal placeholder-charcoal-muted focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                    placeholder="(555) 123-4567" />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="email" class="block text-sm font-medium text-charcoal mb-1.5">Email</label>
                  <input type="email" id="email" name="email" autocomplete="email"
                    class="w-full px-4 py-3 rounded-xl border border-warm-300 bg-warm-50 text-charcoal placeholder-charcoal-muted focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                    placeholder="you@email.com" />
                </div>
                <div>
                  <label for="address" class="block text-sm font-medium text-charcoal mb-1.5">Address</label>
                  <!-- TODO: Connect Google Places Autocomplete API via Manus master key on production -->
                  <input type="text" id="address" name="address" autocomplete="street-address"
                    class="w-full px-4 py-3 rounded-xl border border-warm-300 bg-warm-50 text-charcoal placeholder-charcoal-muted focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                    placeholder="123 Main St, Harrisonburg, VA" />
                </div>
              </div>

              <div>
                <label for="service" class="block text-sm font-medium text-charcoal mb-1.5">Desired Service</label>
                <select id="service" name="service"
                  class="w-full px-4 py-3 rounded-xl border border-warm-300 bg-warm-50 text-charcoal focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all">
                  <option value="">Select a service...</option>
                  {serviceOptions.map(opt => (
                    <option value={opt}>{opt}</option>
                  ))}
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-charcoal mb-1.5">Message</label>
                <textarea id="message" name="message" rows="4"
                  class="w-full px-4 py-3 rounded-xl border border-warm-300 bg-warm-50 text-charcoal placeholder-charcoal-muted focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all resize-none"
                  placeholder="Tell us about your space and what you're looking for..."></textarea>
              </div>

              <button type="submit" class="btn-primary w-full justify-center text-lg">
                Send Request
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </button>
            </form>

            <!-- Success message -->
            <div id="form-success" class="hidden text-center py-12">
              <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              </div>
              <h3 class="text-xl mb-2">Thank You!</h3>
              <p class="text-charcoal-light">We've received your request and will get back to you within 24 hours.</p>
            </div>
          </div>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="lg:col-span-2 reveal">
          <div class="space-y-8">
            <div>
              <h3 class="text-lg mb-4">Contact Information</h3>
              <div class="space-y-4">
                <a href="tel:+15712097745" class="flex items-start gap-3 text-charcoal-light hover:text-green-700 transition-colors group">
                  <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center shrink-0 group-hover:bg-green-200 transition-colors">
                    <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                  </div>
                  <div>
                    <p class="font-medium text-charcoal text-sm">Phone</p>
                    <p class="text-sm">(571) 209-7745</p>
                  </div>
                </a>

                <a href="mailto:hello@galgonegreen.com" class="flex items-start gap-3 text-charcoal-light hover:text-green-700 transition-colors group">
                  <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center shrink-0 group-hover:bg-green-200 transition-colors">
                    <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                  </div>
                  <div>
                    <p class="font-medium text-charcoal text-sm">Email</p>
                    <p class="text-sm">hello@galgonegreen.com</p>
                  </div>
                </a>

                <a href="https://maps.google.com/?q=409+S+Main+Street+Broadway+VA+22815" target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 text-charcoal-light hover:text-green-700 transition-colors group">
                  <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center shrink-0 group-hover:bg-green-200 transition-colors">
                    <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  </div>
                  <div>
                    <p class="font-medium text-charcoal text-sm">Address</p>
                    <p class="text-sm">409 S Main Street<br/>Broadway, VA 22815</p>
                  </div>
                </a>

                <div class="flex items-start gap-3 text-charcoal-light">
                  <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  </div>
                  <div>
                    <p class="font-medium text-charcoal text-sm">Hours</p>
                    <p class="text-sm">Monday - Friday: 8:00 AM - 5:00 PM</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Social -->
            <div>
              <h3 class="text-lg mb-3">Follow Us</h3>
              <a href="https://www.facebook.com/GalGoneGreenCleaning" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-charcoal-light hover:text-green-700 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Facebook
              </a>
            </div>

            <!-- Map -->
            <div class="rounded-2xl overflow-hidden shadow-sm">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3102.8!2d-78.8!3d38.613!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89b4e3c!2s409+S+Main+St%2C+Broadway%2C+VA+22815!5e0!3m2!1sen!2sus!4v1"
                width="100%"
                height="280"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Gal Gone Green location map — 409 S Main Street, Broadway, VA"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    // Check honeypot
    if (formData.get('website')) return;

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' },
      });

      if (res.ok) {
        window.location.href = '/thank-you';
        return;
      } else {
        // Fallback to mailto
        const name = formData.get('name');
        const phone = formData.get('phone');
        const email = formData.get('email');
        const service = formData.get('service');
        const message = formData.get('message');
        const body = `Name: ${name}%0APhone: ${phone}%0AEmail: ${email}%0AService: ${service}%0AMessage: ${message}`;
        window.location.href = `mailto:hello@galgonegreen.com?subject=Cleaning Request from ${name}&body=${body}`;
      }
    } catch {
      // Fallback to mailto on network error
      const name = formData.get('name');
      window.location.href = `mailto:hello@galgonegreen.com?subject=Cleaning Request from ${name}`;
    }
  });
</script>
