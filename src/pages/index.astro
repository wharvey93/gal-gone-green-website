---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import heroImg from '../assets/images/photos/hero-living-room.jpg';
import deepCleanImg from '../assets/images/photos/cleaning-action.jpg';
import commercialImg from '../assets/images/photos/hero-office.jpg';
import airbnbImg from '../assets/images/photos/vacation-rental.jpg';

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Gal Gone Green",
  "image": "https://galgonegreen.com/images/og-default.jpg",
  "url": "https://galgonegreen.com",
  "telephone": "+15712097745",
  "email": "hello@galgonegreen.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "409 S Main Street",
    "addressLocality": "Broadway",
    "addressRegion": "VA",
    "postalCode": "22815",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 38.6132,
    "longitude": -78.7988
  },
  "areaServed": [
    "Harrisonburg, VA", "Broadway, VA", "Bridgewater, VA", "Dayton, VA",
    "Elkton, VA", "Staunton, VA", "Waynesboro, VA", "Mt. Crawford, VA"
  ],
  "description": "Eco-friendly residential and commercial cleaning services in Harrisonburg and the Shenandoah Valley. Locally owned since 2011.",
  "foundingDate": "2011",
  "priceRange": "$$",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "08:00",
    "closes": "17:00"
  },
  "sameAs": ["https://www.facebook.com/GalGoneGreenCleaning"]
};

const taglineOptions = [
  /* OPTION 1 — Recommended */ "Clean Spaces. Clear Minds. Greener Living.",
  /* OPTION 2 */ "Where Clean Meets Conscience.",
  /* OPTION 3 */ "A Healthier Clean for Home and Business.",
  /* OPTION 4 */ "The Clean You Can Feel Good About.",
  /* OPTION 5 */ "Thoughtfully Clean. Naturally Fresh.",
];
const tagline = taglineOptions[0]; // Change index to pick a different tagline

const trustItems = [
  { icon: 'calendar', label: 'Since 2011' },
  { icon: 'shield', label: 'Safer for Your Family' },
  { icon: 'check', label: 'Satisfaction Guaranteed' },
  { icon: 'heart', label: 'Locally Owned' },
];

const services = [
  {
    title: 'Residential Cleaning',
    description: 'Come home to the calm of a spotless space. From recurring upkeep to deep seasonal refreshes, we take care of everything.',
    image: deepCleanImg,
    href: '/residential',
    alt: 'Professional residential deep cleaning in Harrisonburg VA',
  },
  {
    title: 'Commercial Cleaning',
    description: 'A clean workspace says everything about your business. We handle offices, common areas, and high-touch surfaces.',
    image: commercialImg,
    href: '/commercial',
    alt: 'Office and commercial cleaning services in Shenandoah Valley',
  },
  {
    title: 'Short-Term Rental',
    description: 'Guest-ready turnovers that earn 5-star reviews. We treat your rental like we would be the ones staying there.',
    image: airbnbImg,
    href: '/commercial#airbnb',
    alt: 'Airbnb and vacation rental turnover cleaning in Virginia',
  },
];

const yearsInBusiness = new Date().getFullYear() - 2011;

const differentiators = [
  { icon: 'leaf', title: 'Safer Products', desc: 'Products that are safer for your family, your pets, and your home.' },
  { icon: 'clock', title: `${yearsInBusiness}+ Years Experience`, desc: 'Serving the Shenandoah Valley with care and consistency since 2011.' },
  { icon: 'refresh', title: 'Satisfaction Guarantee', desc: "Not satisfied? We'll re-clean within 24 hours at no extra charge." },
  { icon: 'tools', title: 'All Supplies Provided', desc: "We bring everything — you don't need to prepare a thing." },
  { icon: 'home', title: 'Locally Owned', desc: 'Not a franchise. Personal attention and accountability on every job.' },
  { icon: 'calendar-check', title: 'Flexible Scheduling', desc: 'One-time, bi-weekly, or monthly — whatever fits your life.' },
];

const areas = [
  { name: 'Harrisonburg', slug: 'harrisonburg' },
  { name: 'Broadway', slug: 'broadway' },
  { name: 'Bridgewater', slug: 'bridgewater' },
  { name: 'Dayton', slug: 'dayton' },
  { name: 'Elkton', slug: 'elkton' },
  { name: 'Staunton', slug: 'staunton' },
  { name: 'Waynesboro', slug: 'waynesboro' },
  { name: 'Mt. Crawford', slug: 'mt-crawford' },
  { name: 'Timberville', slug: 'timberville' },
  { name: 'Grottoes', slug: 'grottoes' },
];
---

<BaseLayout
  title="Eco-Friendly House Cleaning in Harrisonburg, VA | Gal Gone Green"
  description="Professional eco-friendly cleaning for homes and businesses across Harrisonburg and the Shenandoah Valley. Locally owned since 2011. Safer products, satisfaction guaranteed."
  canonicalPath=""
  schema={schema}
>
  <!-- ===== HERO ===== -->
  <section class="relative min-h-[70vh] md:min-h-[80vh] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={heroImg}
        alt="Beautiful clean living room in a Shenandoah Valley home"
        class="w-full h-full object-cover"
        widths={[640, 1024, 1440, 1920]}
        sizes="100vw"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-green-950/80 via-green-900/60 to-green-900/30"></div>
    </div>

    <div class="container relative z-10 py-20">
      <div class="max-w-2xl">
        <p class="text-green-300 font-medium text-sm uppercase tracking-widest mb-4 reveal">Eco-Friendly Cleaning</p>
        <h1 class="text-white text-4xl md:text-5xl lg:text-6xl font-[var(--font-heading)] leading-tight mb-4 reveal text-balance">
          Eco-Friendly Cleaning for Your Harrisonburg Home &amp; Business
        </h1>
        <p class="text-green-200 text-xl md:text-2xl font-[var(--font-heading)] mb-6 reveal">{tagline}</p>
        <p class="text-green-100/90 text-lg md:text-xl leading-relaxed mb-10 max-w-xl reveal">
          Since 2011, families and businesses across the Shenandoah Valley have trusted Gal Gone Green for cleaning that's as thoughtful as it is thorough. Locally owned, never a franchise.
        </p>
        <div class="flex flex-wrap gap-4 reveal">
          <a href="/contact" class="btn-primary text-lg">
            Book a Cleaning
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="#services" class="btn-white text-lg">
            See Our Services
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce hidden md:block">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
    </div>
  </section>

  <!-- ===== TRUST BAR ===== -->
  <section class="bg-green-700 text-white py-5 relative grain">
    <div class="container">
      <div class="flex flex-wrap justify-center gap-x-10 gap-y-3">
        {trustItems.map(item => (
          <div class="flex items-center gap-2.5 text-sm font-medium reveal">
            {item.icon === 'calendar' && <svg class="w-5 h-5 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>}
            {item.icon === 'shield' && <svg class="w-5 h-5 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>}
            {item.icon === 'check' && <svg class="w-5 h-5 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
            {item.icon === 'heart' && <svg class="w-5 h-5 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>}
            <span>{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES OVERVIEW ===== -->
  <section id="services" class="section-padding bg-cream">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-14 reveal">
        <p class="text-green-600 font-medium text-sm uppercase tracking-widest mb-3">What We Do</p>
        <h2 class="mb-4">Cleaning Services That Fit Your Life</h2>
        <p class="text-charcoal-light text-lg">Whether it's your home, your office, or your Airbnb, we bring the same care and attention to every space we clean.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {services.map((svc, i) => (
          <a href={svc.href} class="group card-hover bg-white rounded-2xl overflow-hidden shadow-sm reveal" style={`transition-delay: ${i * 100}ms`}>
            <div class="aspect-[4/3] overflow-hidden">
              <Image
                src={svc.image}
                alt={svc.alt}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                widths={[400, 600]}
                sizes="(max-width: 768px) 100vw, 33vw"
              />
            </div>
            <div class="p-7">
              <h3 class="text-xl mb-2 group-hover:text-green-600 transition-colors">{svc.title}</h3>
              <p class="text-charcoal-light text-sm leading-relaxed mb-4">{svc.description}</p>
              <span class="text-green-600 font-medium text-sm flex items-center gap-1.5 group-hover:gap-3 transition-all">
                Learn More
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHY CHOOSE GGG ===== -->
  <section class="section-padding bg-green-50 relative grain">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-14 reveal">
        <p class="text-green-600 font-medium text-sm uppercase tracking-widest mb-3">Why Gal Gone Green</p>
        <h2 class="mb-4">More Than Just a Cleaning Service</h2>
        <p class="text-charcoal-light text-lg">We've spent over a decade earning the trust of families and businesses in the Shenandoah Valley. Here's what sets us apart.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {differentiators.map((d, i) => (
          <div class="bg-white rounded-2xl p-7 shadow-sm card-hover reveal" style={`transition-delay: ${i * 80}ms`}>
            <div class="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center mb-4">
              {d.icon === 'leaf' && <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>}
              {d.icon === 'clock' && <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
              {d.icon === 'refresh' && <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
              {d.icon === 'tools' && <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>}
              {d.icon === 'home' && <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>}
              {d.icon === 'calendar-check' && <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>}
            </div>
            <h3 class="text-lg mb-1.5">{d.title}</h3>
            <p class="text-charcoal-light text-sm leading-relaxed">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="section-padding bg-white">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-14 reveal">
        <p class="text-green-600 font-medium text-sm uppercase tracking-widest mb-3">Simple Process</p>
        <h2>How It Works</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto relative">
        <!-- Connecting line (desktop only) — centered through the step circles -->
        <div class="hidden md:block absolute top-7 left-[calc(16.67%+28px)] right-[calc(16.67%+28px)] h-0.5 bg-green-200 z-0"></div>

        {[
          { step: '1', title: 'Tell Us About Your Space', desc: 'Fill out a quick form or give us a call. We\'ll ask about your home or business and recommend the right service.' },
          { step: '2', title: 'Pick a Time That Works', desc: 'Choose a date and frequency — one-time, bi-weekly, or monthly. We build our schedule around yours.' },
          { step: '3', title: 'Enjoy Your Clean Space', desc: 'Our team shows up with everything needed. Walk in to a home that feels like new — every single time.' },
        ].map((item, i) => (
          <div class="text-center reveal" style={`transition-delay: ${i * 150}ms`}>
            <div class="w-14 h-14 rounded-full bg-green-600 text-white flex items-center justify-center text-xl font-bold font-[var(--font-heading)] mx-auto mb-5 relative z-10 shadow-lg shadow-green-600/20 ring-4 ring-white">
              {item.step}
            </div>
            <h3 class="text-lg mb-2">{item.title}</h3>
            <p class="text-charcoal-light text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-12 reveal">
        <a href="/contact" class="btn-primary">
          Book a Cleaning
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="section-padding bg-cream">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-10 reveal">
        <p class="text-green-600 font-medium text-sm uppercase tracking-widest mb-3">What People Say</p>
        <h2 class="mb-3">Trusted by Your Neighbors</h2>
      </div>

      <!-- Review carousel -->
      <div class="relative max-w-5xl mx-auto reveal">
        <div id="review-track" class="flex gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4 -mx-4 px-4" style="scrollbar-width: none; -ms-overflow-style: none;">
          {[
            { quote: "Cannot say enough good things... they leave things in perfect shape, and are so fast and such nice people!! I will continue to use them for a long time!", name: 'Lori Petrie', source: 'Google Review', stars: 5 },
            { quote: "Very professional and friendly. My house smells great and furniture and floors are shiny. Bathrooms are fresh and clean.", name: 'Caroljean Kacho', source: 'Google Review', stars: 5 },
            { quote: "Gal Gone Green cleans the office at my workplace, and they do a wonderful job each week. Desks are wiped, floors are cleaned, dishes put away, break room wiped down, bathrooms are spotless. They have been cleaning for us since 2021, and we have been very happy with their services.", name: 'Angie Lockard', source: 'Google Review', stars: 5 },
            { quote: "I'm thankful that I am assigned the same cleaner each time. She knows me and my house and so we are able to communicate easily about what needs to be done. I love how my bathrooms sparkle, and the house and floors are green clean. I'm sensitive to chemicals, but I've never had a reaction to the products that are used.", name: 'Vicki Nolt', source: 'Google Review', stars: 5 },
            { quote: "It was so wonderful to come home to such a clean home! I have four dogs that shed, and you could not even tell! Everything was dusted, mopped and straightened! Bathrooms were sparkling clean!", name: 'Carrie Streett', source: 'Google Review', stars: 5 },
            { quote: "Gal Gone Green is an amazing eco-friendly cleaning company. I'm always in awe of how clean my house is after a cleaning. My space is spotless, and the air felt noticeably fresher without the usual harsh chemical smells. The team is on time, professional, and genuinely invested in their work.", name: 'Phil Ernst', source: 'Google Review', stars: 5 },
            { quote: "Very efficient, dependable, and trustworthy are the words that come to my mind when I think of Gal Gone Green. I can not say enough good things about their work. Gal Gone Green has been cleaning for me since October 2023. I highly recommend them!", name: 'Debbi Long', source: 'Google Review', stars: 5 },
            { quote: "We have been so impressed with the cleaning done by Gal Gone Green. They helped us out several times over the course of three different house moves, accommodating last minute schedule changes with no complaints, and did an amazing job at each location. Prices are super reasonable and their work is worth every penny!", name: 'Rachael Harnish', source: 'Facebook Review', stars: 5 },
            { quote: "Gal Gone Green did a wonderful job in preparing a house to enter the real estate market. They were very accommodating and fit us quickly into their schedule and the cleaning surpassed my expectations. I would highly recommend this cleaning service.", name: 'Laura Evick', source: 'Facebook Review', stars: 5 },
          ].map((t, i) => (
            <div class="bg-white rounded-2xl p-7 shadow-sm flex-shrink-0 w-[320px] md:w-[380px] snap-start relative flex flex-col">
              <svg class="w-8 h-8 text-green-100 absolute top-5 right-5" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" /></svg>
              <div class="flex gap-0.5 mb-3">
                {Array(t.stars).fill(null).map(() => (
                  <svg class="w-4 h-4 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                ))}
              </div>
              <p class="text-charcoal-light text-sm leading-relaxed mb-5 flex-1 italic">"{t.quote}"</p>
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-700 font-semibold text-xs">
                  {t.name.split(' ').map(n => n[0]).join('')}
                </div>
                <div>
                  <p class="font-semibold text-sm text-charcoal">{t.name}</p>
                  <p class="text-charcoal-muted text-xs flex items-center gap-1">
                    {t.source === 'Google Review' && <svg class="w-3 h-3" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>}
                    {t.source === 'Facebook Review' && <svg class="w-3 h-3" viewBox="0 0 24 24"><path fill="#1877F2" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>}
                    {t.source}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Navigation arrows -->
        <button id="review-prev" type="button" class="hidden md:flex absolute -left-5 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white shadow-md items-center justify-center text-green-700 hover:bg-green-50 transition-colors z-10" aria-label="Previous reviews">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        </button>
        <button id="review-next" type="button" class="hidden md:flex absolute -right-5 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white shadow-md items-center justify-center text-green-700 hover:bg-green-50 transition-colors z-10" aria-label="Next reviews">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </button>

        <!-- Dot indicators -->
        <div class="flex justify-center gap-2 mt-6">
          {Array(9).fill(null).map((_, i) => (
            <button class="review-dot w-2 h-2 rounded-full bg-green-300 transition-all" data-index={i} aria-label={`Go to review ${i + 1}`}></button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    const track = document.getElementById('review-track');
    const prevBtn = document.getElementById('review-prev');
    const nextBtn = document.getElementById('review-next');
    const dots = document.querySelectorAll('.review-dot');
    const cardWidth = 396; // 380 + 16 gap

    function updateDots() {
      if (!track) return;
      const scrollLeft = track.scrollLeft;
      const index = Math.round(scrollLeft / cardWidth);
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-green-600', i === index);
        dot.classList.toggle('bg-green-300', i !== index);
        dot.classList.toggle('w-4', i === index);
        dot.classList.toggle('w-2', i !== index);
      });
    }

    prevBtn?.addEventListener('click', () => {
      track?.scrollBy({ left: -cardWidth, behavior: 'smooth' });
    });
    nextBtn?.addEventListener('click', () => {
      track?.scrollBy({ left: cardWidth, behavior: 'smooth' });
    });
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        const index = Number(dot.dataset.index);
        track?.scrollTo({ left: index * cardWidth, behavior: 'smooth' });
      });
    });
    track?.addEventListener('scroll', updateDots, { passive: true });
    updateDots();

    // Auto-advance every 5 seconds
    let autoplay = setInterval(() => {
      if (!track) return;
      const maxScroll = track.scrollWidth - track.clientWidth;
      if (track.scrollLeft >= maxScroll - 10) {
        track.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        track.scrollBy({ left: cardWidth, behavior: 'smooth' });
      }
    }, 5000);

    // Pause autoplay on hover/touch
    track?.addEventListener('mouseenter', () => clearInterval(autoplay));
    track?.addEventListener('touchstart', () => clearInterval(autoplay), { passive: true });
  </script>

