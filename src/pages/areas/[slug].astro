---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locations, getNeighborLocations } from '../../data/locations';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return locations.map(loc => ({ params: { slug: loc.slug }, props: { location: loc } }));
};

const { location } = Astro.props;
const neighbors = getNeighborLocations(location.neighborLinks);

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Gal Gone Green",
  "telephone": "+15712097745",
  "email": "hello@galgonegreen.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "409 S Main Street",
    "addressLocality": "Broadway",
    "addressRegion": "VA",
    "postalCode": "22815"
  },
  "areaServed": {
    "@type": "City",
    "name": `${location.name}, Virginia`
  },
  "description": `Eco-friendly residential and commercial cleaning services in ${location.name}, VA. Locally owned since 2011.`
};

const faqSchema = location.faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": location.faq.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
} : null;
---

<BaseLayout
  title={`Eco-Friendly House Cleaning in ${location.name}, VA | Gal Gone Green`}
  description={`Professional eco-friendly cleaning services in ${location.name}, Virginia. Residential, commercial, and Airbnb cleaning. Locally owned since 2011. Satisfaction guaranteed.`}
  canonicalPath={`/areas/${location.slug}`}
  schema={schema}
>
  <!-- Hero -->
  <section class="py-16 md:py-24 bg-green-800 relative grain">
    <div class="container relative z-10">
      <div class="max-w-3xl">
        <p class="text-green-300 font-medium text-sm uppercase tracking-widest mb-4 reveal">{location.county} &middot; {location.driveMinutes === 0 ? 'Our Home Base' : `~${location.driveMinutes} min from Broadway`}</p>
        <h1 class="text-white mb-6 reveal">{location.h1}</h1>
        <p class="text-green-100/80 text-lg leading-relaxed reveal">{location.intro}</p>
        <div class="mt-8 reveal">
          <a href="/contact" class="btn-primary">
            Book a Cleaning in {location.name}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Available -->
  <section class="section-padding bg-cream">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <div class="lg:col-span-3">
          <div class="reveal">
            <h2 class="mb-4">Services Available in {location.name}</h2>
            <p class="text-charcoal-light leading-relaxed mb-6">{location.serviceEmphasis}</p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
            {[
              { title: 'One-Time Deep Cleaning', desc: 'Top-to-bottom thorough cleaning', href: '/residential#deep-cleaning' },
              { title: 'Recurring Bi-Weekly', desc: 'Consistent upkeep every 2 weeks', href: '/residential#recurring' },
              { title: 'Recurring Monthly', desc: 'Monthly refresh for your home', href: '/residential#recurring' },
              { title: 'Office Cleaning', desc: 'Professional workspace cleaning', href: '/commercial' },
              { title: 'Airbnb / Short-Term Rental', desc: 'Guest-ready turnovers', href: '/commercial#airbnb' },
              { title: 'Move-In / Move-Out', desc: 'Deep clean for transitions', href: '/commercial' },
            ].map((svc, i) => (
              <a href={svc.href} class="bg-white rounded-xl p-5 shadow-sm card-hover group reveal" style={`transition-delay: ${i * 50}ms`}>
                <h3 class="text-base group-hover:text-green-600 transition-colors mb-1 font-[var(--font-body)] font-semibold">{svc.title}</h3>
                <p class="text-charcoal-muted text-sm">{svc.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2 reveal">
          <div class="bg-green-50 rounded-2xl p-8 sticky top-24">
            <h3 class="text-lg mb-4">Why {location.name} Residents Choose Gal Gone Green</h3>
            <ul class="space-y-3 mb-6">
              {location.whyChoose.map(item => (
                <li class="flex items-start gap-2.5 text-sm text-charcoal-light">
                  <svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <a href="/contact" class="btn-primary w-full justify-center">Get a Free Quote</a>
            <div class="mt-6 pt-6 border-t border-green-200 space-y-2">
              <a href="tel:+15712097745" class="flex items-center gap-2 text-sm text-charcoal-light hover:text-green-700 transition-colors">
                <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                (571) 209-7745
              </a>
              <a href="mailto:hello@galgonegreen.com" class="flex items-center gap-2 text-sm text-charcoal-light hover:text-green-700 transition-colors">
                <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                hello@galgonegreen.com
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Local Knowledge -->
  <section class="section-padding bg-white">
    <div class="container">
      <div class="max-w-3xl reveal">
        <h2 class="mb-4">We Know {location.name}</h2>
        <p class="text-charcoal-light leading-relaxed text-lg">{location.localKnowledge}</p>
        {location.driveMinutes > 0 && (
          <p class="text-charcoal-light leading-relaxed mt-4">
            Located just {location.driveMinutes} minutes from our home base in Broadway, we provide the same exceptional service to {location.name} that our neighbors have trusted for over a decade.
          </p>
        )}
        {location.externalLink && (
          <p class="mt-4">
            <a href={location.externalLink.url} target="_blank" rel="noopener noreferrer" class="text-green-600 hover:text-green-800 font-medium text-sm">
              Learn more about {location.externalLink.label} &rarr;
            </a>
          </p>
        )}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  {location.faq.length > 0 && (
    <section class="section-padding bg-green-50 relative grain">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <div class="text-center mb-10 reveal">
            <h2>Frequently Asked Questions — {location.name}</h2>
          </div>
          <div class="space-y-4">
            {location.faq.map((item, i) => (
              <details class="group bg-white rounded-xl shadow-sm reveal" style={`transition-delay: ${i * 60}ms`}>
                <summary class="flex items-center justify-between cursor-pointer p-6 text-charcoal font-medium hover:text-green-700 transition-colors">
                  <span class="pr-4">{item.q}</span>
                  <svg class="w-5 h-5 text-green-600 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </summary>
                <div class="px-6 pb-6 text-charcoal-light text-sm leading-relaxed">
                  {item.a}
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Nearby Areas -->
  {neighbors.length > 0 && (
    <section class="section-padding bg-cream">
      <div class="container">
        <div class="text-center mb-8 reveal">
          <h2>Nearby Service Areas</h2>
          <p class="text-charcoal-light mt-2">We also serve these communities near {location.name}.</p>
        </div>
        <div class="flex flex-wrap justify-center gap-3 reveal">
          {neighbors.map(n => (
            <a href={`/areas/${n.slug}`} class="px-5 py-2.5 bg-white rounded-full shadow-sm hover:shadow-md hover:bg-green-50 text-charcoal text-sm font-medium transition-all">
              {n.name}
            </a>
          ))}
          <a href="/areas" class="px-5 py-2.5 border-2 border-green-500 rounded-full text-green-700 hover:bg-green-50 text-sm font-medium transition-all">
            View All Areas &rarr;
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section-padding bg-green-800 text-white relative grain">
    <div class="container text-center reveal">
      <h2 class="text-white mb-4">Ready for a Cleaner Home in {location.name}?</h2>
      <p class="text-green-100/80 text-lg mb-8 max-w-xl mx-auto">
        Book your first cleaning and see why families across the Shenandoah Valley trust Gal Gone Green.
      </p>
      <a href="/contact" class="btn-primary text-lg">
        Book a Cleaning
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </section>

  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</BaseLayout>
